DB_URL=jdbc:postgresql://host:port/database
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

JPA_DDL_AUTO=update
JPA_FORMAT_SQL=true
JPA_SHOW_SQL=false

REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

JWT_SECRET=your-jwt-secret
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=14

KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_REDIRECT_URI=https://your-domain/api/auth/kakao/callback

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain/api/auth/google/callback

APP_FRONTEND_URL=runboo://

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-mail-username
MAIL_PASSWORD=your-mail-password
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true

REQUEST_MAPPING_LOG_LEVEL=INFO

AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_MODEL=gemini-flash-latest

SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8080

GOOGLE_APPLICATION_CREDENTIALS=backSecrets/runboo-fcm.json

VITE_API_BASE_URL=https://your-domain
ADMIN_PASSWORD=change-me
